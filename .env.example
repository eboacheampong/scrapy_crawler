# Environment configuration for Render deployment
FLASK_ENV=production
PORT=5000

# Optional: Add your sources
# SCRAPER_SOURCES=https://techcrunch.com,https://theverge.com

# Optional: Add any API keys if needed in future
# API_KEY=your_key_here

# Optional: Add database URL if connecting to external DB
# DATABASE_URL=postgresql://user:password@host:port/db

# ─── SOCIAL MEDIA SCRAPER CONFIG ─────────────────────────────────────────

# ScrapeCreators — PAID PRIMARY (all platforms, 1 credit/request)
# Sign up at https://app.scrapecreators.com (100 free credits, no CC required)
# Get your API key from the dashboard after signing up
SCRAPECREATORS_API_KEY=

# Max credits per scrape run (default: 6)
# Only TikTok, Instagram, Reddit use ScrapeCreators (keyword search).
# Twitter, Facebook, LinkedIn use Bing fallback (no keyword search on SC).
# TikTok uses `query` param on /v1/tiktok/search/keyword
# Instagram uses `query` param on /v2/instagram/reels/search
# Math: 3 keywords × 2 platforms (tiktok + instagram) = 6 credits per run.
# Reddit is free via JSON API so SC reddit is optional.
SCRAPECREATORS_BUDGET=6

# Twitter/X — twscrape requires authenticated accounts (FREE FALLBACK).
# Option 1: Path to accounts.db file (created via twscrape CLI)
# TWSCRAPE_DB=accounts.db
#
# Option 2: Add accounts via twscrape CLI:
#   twscrape add_accounts accounts.txt username:password:email:email_password
#   twscrape login_accounts
#
# Option 3: Add account with cookies (more stable):
#   twscrape add_accounts --cookies "ct0=xxx;auth_token=yyy" username password email email_pass

# LinkedIn — requires a LinkedIn account
# LINKEDIN_EMAIL=your_linkedin_email@example.com
# LINKEDIN_PASSWORD=your_linkedin_password

# Instagram — instaloader works without login for public content.
# For private profiles or higher rate limits, set credentials:
# INSTAGRAM_USERNAME=your_username
# INSTAGRAM_PASSWORD=your_password

# Facebook — facebook-scraper works without login for public pages.
# For better results, you can set cookies:
# FACEBOOK_COOKIES=c_user=xxx;xs=yyy

# TikTok — TikTokApi works without login.
# For better results, set ms_token from browser:
# TIKTOK_MS_TOKEN=your_ms_token_here

# YouTube — scrapetube is used by default (free, no API key needed)
# Optionally set a YouTube Data API v3 key as fallback if scrapetube breaks
# Get your API key from https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=
